# ============================================================
# Environment Variables - Automation Warehouse
# ============================================================
# Copy this file to .env and adjust for your environment:
#   - Docker: use service names (postgres, rabbitmq, n8n)
#   - Local dev: use localhost
# ============================================================

# -----------------------------------------------------------
# Application
# -----------------------------------------------------------
PROJECT_NAME="Automation Warehouse API"
ENVIRONMENT=DEVELOPMENT
API_VERSION=v1
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------
# PostgreSQL Database
# Docker: POSTGRES_HOST=postgres
# Local:  POSTGRES_HOST=localhost
# -----------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=core_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------
# RabbitMQ (Celery message broker)
# Docker: RABBITMQ_HOST=rabbitmq
# Local:  RABBITMQ_HOST=localhost
# -----------------------------------------------------------
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# -----------------------------------------------------------
# Celery (background tasks via RabbitMQ)
# Docker: amqp://admin:admin@rabbitmq:5672//
# Local:  amqp://admin:admin@localhost:5672//
# -----------------------------------------------------------
CELERY_BROKER_URL=amqp://admin:admin@localhost:5672//
CELERY_RESULT_BACKEND=rpc://

# -----------------------------------------------------------
# N8N (workflow automation)
# Docker: N8N_BASE_URL=http://n8n:5678
# Local:  N8N_BASE_URL=http://localhost:5678
# -----------------------------------------------------------
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678
N8N_API_KEY=
N8N_API_KEY_HEADER=X-API-Key

# N8N basic auth (for UI access)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# -----------------------------------------------------------
# Flower (Celery monitoring)
# -----------------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=admin

# -----------------------------------------------------------
# Email Service (optional — defaults to SMTP placeholder)
# -----------------------------------------------------------
EMAIL_PROVIDER=smtp
EMAIL_FROM_NAME=Equipo
SMTP_HOST=c2661555.ferozo.com
# SMTP_PORT — picks the TLS mode automatically:
#   465  → implicit SSL (smtplib.SMTP_SSL); SMTP_USE_TLS is ignored.
#   587  → STARTTLS (smtplib.SMTP + starttls()); set SMTP_USE_TLS=true.
#   25 / 2525 → plain SMTP; set SMTP_USE_TLS=false (only for local relays).
SMTP_PORT=587
SMTP_USERNAME=administracion@mendrisoftware.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=dev-noreply@mendrisoftware.com
SMTP_USE_TLS=true
# Cap the blocking SMTP session in seconds — prevents indefinite hangs
# on unreachable / misconfigured servers.
SMTP_TIMEOUT_SECONDS=30
EMAIL_API_URL=
EMAIL_API_KEY=
EMAIL_API_KEY_HEADER=Authorization
EMAIL_FROM_EMAIL=dev-noreply@mendrisoftware.com

# -----------------------------------------------------------
# Frontend URL (for email links, CORS)
# -----------------------------------------------------------
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:80"]

# -----------------------------------------------------------
# Frontend
# -----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------
# AFIP / ARCA (Argentine electronic invoicing — shared/afip)
# -----------------------------------------------------------
# Leave the four required fields below unset on any deployment that does
# not need invoicing — the integration stays inert until configured.
# Only Argentine clients of the agency populate this section.
#
# Cert and key files must NOT be committed (the certs/ folder at repo
# root is gitignored). On the server, upload them out-of-band and point
# AFIP_CERT_PATH / AFIP_KEY_PATH at their absolute path.
# -----------------------------------------------------------
AFIP_ENVIRONMENT=homo            # homo | prod
AFIP_CUIT=                       # 11 digits, no separators
AFIP_POINT_OF_SALE=              # integer; matches a Pto.Vta. enabled for the CUIT
AFIP_CERT_PATH=                  # absolute path to X.509 cert (PEM)
AFIP_KEY_PATH=                   # absolute path to private key (PEM)

# Optional — defaults shown:
# AFIP_CURRENCY_ID=PES
# AFIP_TIMEOUT_SECONDS=30
# AFIP_MAX_RETRIES=3
# AFIP_TOKEN_REFRESH_THRESHOLD_MINUTES=30
# AFIP_RG4444_THRESHOLD_ARS=0    # 0 disables the local receiver-ID check
