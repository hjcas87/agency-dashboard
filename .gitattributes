# Archivos custom que deben mantenerse en ramas custom durante merges
# merge=ours significa: cuando hay conflicto, mantener la versión de la rama actual (custom)
# Esto evita conflictos al hacer merge desde main a ramas custom

# Archivos de configuración custom por cliente
frontend/app/(private)/page.tsx merge=ours
frontend/components/custom/** merge=ours
frontend/app/actions/custom/** merge=ours
frontend/app/(private)/**/page.tsx merge=ours

# Archivos core que siempre deben tomarse de main
frontend/app/(private)/layout.tsx merge=theirs
frontend/components/core/** merge=theirs
frontend/app/actions/core/** merge=theirs
